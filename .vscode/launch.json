<!DOCTYPE html>
<html lang="en" data-theme="premium">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Black Label — Czech Inn Hotels Premium Experiences</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400;1,500&family=Heebo:wght@100;200;300;400;500;700;900&display=swap" rel="stylesheet">
<link rel="stylesheet" href="shared.css">

<style>
/* ═══════════════════════════════════════════
   BLACK LABEL PAGE-SPECIFIC STYLES
   ═══════════════════════════════════════════ */

/* Hero with Ken Burns */
.bl-hero{position:relative;min-height:100vh;display:flex;align-items:center;justify-content:center;text-align:center;overflow:hidden}
.bl-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 40%,rgba(184,147,58,.06) 0%,transparent 60%);z-index:1}
.bl-hero::after{content:'';position:absolute;bottom:0;left:0;right:0;height:240px;background:linear-gradient(transparent,var(--bg));z-index:1}
.bl-hero-bg{position:absolute;inset:0;background:url('https://images.unsplash.com/photo-1519677100203-a0e668c92439?w=1800&q=80') center/cover;filter:brightness(.15) saturate(.4);animation:kenBurns 20s ease infinite alternate}
.bl-hero-content{position:relative;z-index:2;padding:40px}
.bl-label-tag{display:inline-block;padding:8px 28px;border:1px solid var(--accent);font-size:.6rem;color:var(--accent);text-transform:uppercase;letter-spacing:8px;margin-bottom:28px;opacity:0;animation:fadeUp .8s .3s forwards;transform:translateY(20px)}
.bl-hero h1{font-family:var(--fd);font-size:clamp(3rem,6vw,5.5rem);font-weight:300;color:var(--brand-cream);line-height:1.05;letter-spacing:-1px;opacity:0;animation:fadeUp .8s .6s forwards;transform:translateY(30px)}
.bl-hero h1 em{font-style:italic;color:var(--accent);font-weight:400}
.bl-hero-line{width:60px;height:1px;background:var(--accent);margin:28px auto;opacity:0;animation:fadeUp .8s .9s forwards;transform:translateY(10px)}
.bl-hero p{font-size:1rem;color:var(--brand-tan);font-weight:200;max-width:540px;margin:0 auto;line-height:1.8;letter-spacing:.3px;opacity:0;animation:fadeUp .8s 1.1s forwards;transform:translateY(20px)}
.bl-hero-cta{margin-top:36px;opacity:0;animation:fadeUp .8s 1.4s forwards;transform:translateY(20px)}
.bl-hero-scroll{position:absolute;bottom:40px;left:50%;transform:translateX(-50%);z-index:2;color:var(--accent);font-size:.64rem;letter-spacing:3px;text-transform:uppercase;opacity:0;animation:fadeUp .8s 1.7s forwards}
.bl-hero-scroll::after{content:'';display:block;width:1px;height:40px;background:var(--accent);margin:8px auto 0;opacity:.4}

/* Section dark override for premium */
.bl-sec-dark{background:var(--surface);border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:100px 40px}
.bl-sec-dark .bl-inner{max-width:1240px;margin:0 auto}

/* Upgrade grid */
.up-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:18px}
.up-card{background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:26px 22px;transition:border-color .3s,transform .3s,box-shadow .3s;position:relative;overflow:hidden}
.up-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--shimmer);background-size:200% auto;animation:shim 3s linear infinite;opacity:0;transition:opacity .3s}
.up-card:hover{border-color:var(--accent);transform:translateY(-3px);box-shadow:var(--card-hover-shadow)}
.up-card:hover::before{opacity:1}
.up-icon{font-size:1.6rem;margin-bottom:12px}
.up-card h4{font-family:var(--fd);font-size:1.1rem;font-weight:500;color:var(--heading);margin-bottom:5px}
.up-card p{font-size:.76rem;color:var(--text-l);line-height:1.7;font-weight:200;margin-bottom:12px}
.up-price{font-family:var(--fd);font-size:1.05rem;font-weight:600;color:var(--accent)}

/* Experience cards (large image) */
.exp-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:22px}
.exp-card{background:var(--surface);border:1px solid var(--border);border-radius:14px;overflow:hidden;transition:border-color .3s,transform .3s,box-shadow .3s;position:relative}
.exp-card::before{content:'';position:absolute;top:0;left:0;right:0;height:2px;background:var(--shimmer);background-size:200% auto;animation:shim 3s linear infinite;opacity:0;transition:opacity .3s;z-index:2}
.exp-card:hover{border-color:var(--accent);transform:translateY(-4px);box-shadow:var(--card-hover-shadow)}
.exp-card:hover::before{opacity:1}
.exp-img{height:210px;overflow:hidden;position:relative}
.exp-img img{width:100%;height:100%;object-fit:cover;filter:brightness(.45) saturate(.6);transition:all .6s}
.exp-card:hover .exp-img img{filter:brightness(.6) saturate(.7);transform:scale(1.04)}
.exp-img-badge{position:absolute;top:12px;left:12px;padding:4px 12px;font-size:.6rem;letter-spacing:2px;text-transform:uppercase;color:var(--accent);border:1px solid rgba(184,147,58,.3);backdrop-filter:blur(8px);background:rgba(15,13,15,.6);border-radius:3px}
.exp-img-price{position:absolute;bottom:12px;right:14px;font-family:var(--fd);font-size:1.3rem;font-weight:600;color:var(--accent);text-shadow:0 2px 12px rgba(0,0,0,.7)}
.exp-body{padding:22px}
.exp-body h3{font-family:var(--fd);font-size:1.2rem;font-weight:500;color:var(--heading);margin-bottom:4px}
.exp-meta{font-size:.7rem;color:var(--accent);letter-spacing:.5px;margin-bottom:8px}
.exp-body>p{font-size:.78rem;color:var(--text-l);line-height:1.7;font-weight:200;margin-bottom:12px}
.exp-details{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:14px}
.exp-det{font-size:.7rem;color:var(--text-l);display:flex;align-items:center;gap:3px}
.exp-det span{color:var(--accent)}
.exp-book{display:block;width:100%;padding:12px;background:transparent;border:1px solid var(--accent);color:var(--accent);font-family:var(--fb);font-size:.76rem;letter-spacing:2px;text-transform:uppercase;cursor:pointer;border-radius:5px;transition:all .3s;text-align:center}
.exp-book:hover{background:var(--accent);color:var(--bg)}

/* Concierge grid */
.con-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:16px}
.con-card{background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:22px 16px;text-align:center;transition:border-color .3s,transform .3s}
.con-card:hover{border-color:var(--accent);transform:translateY(-3px)}
.con-icon{font-size:1.5rem;margin-bottom:8px}
.con-card h4{font-family:var(--fd);font-size:.92rem;font-weight:500;color:var(--heading);margin-bottom:3px}
.con-card p{font-size:.7rem;color:var(--text-l);line-height:1.6;font-weight:200;margin-bottom:8px}
.con-price{font-family:var(--fd);font-size:.92rem;font-weight:600;color:var(--accent)}

/* Package cards */
.pkg-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:22px}
.pkg-card{background:var(--surface);border:1px solid var(--border);border-radius:14px;overflow:hidden;transition:all .3s;position:relative}
.pkg-card.featured{border-color:var(--accent);animation:glow 4s infinite}
.pkg-card:hover{transform:translateY(-4px)}
.pkg-head{padding:26px 22px;text-align:center;border-bottom:1px solid var(--border)}
.pkg-badge{font-size:.58rem;color:var(--accent);letter-spacing:3px;text-transform:uppercase;margin-bottom:6px}
.pkg-head h3{font-family:var(--fd);font-size:1.5rem;font-weight:400;color:var(--heading)}
.pkg-price{font-family:var(--fd);font-size:2rem;font-weight:600;color:var(--accent);margin-top:6px}
.pkg-per{font-size:.7rem;color:var(--text-l);font-weight:200}
.pkg-body{padding:22px}
.pkg-item{display:flex;align-items:flex-start;gap:8px;padding:7px 0;border-bottom:1px solid rgba(184,147,58,.06);font-size:.78rem;color:var(--text-l);line-height:1.5}
.pkg-item:last-child{border-bottom:none}
.pkg-check{color:var(--accent);flex-shrink:0}
.pkg-cta{display:block;width:calc(100% - 44px);margin:0 22px 22px;padding:13px;text-align:center;border-radius:5px;font-family:var(--fb);font-size:.76rem;letter-spacing:2px;text-transform:uppercase;cursor:pointer;transition:all .3s}
.pkg-cta-outline{background:transparent;border:1px solid var(--accent);color:var(--accent)}
.pkg-cta-outline:hover{background:var(--accent);color:var(--bg)}
.pkg-cta-gold{background:var(--shimmer);background-size:200% auto;animation:shim 3s linear infinite;border:none;color:#fff}
.pkg-cta-gold:hover{box-shadow:0 8px 24px rgba(184,147,58,.3)}

/* Revenue mini section */
.rev-compare{display:grid;grid-template-columns:1fr 60px 1fr;gap:0;align-items:stretch;margin-top:48px}
.rev-col{border-radius:12px;padding:32px 28px;border:1px solid var(--border)}
.rev-std{background:var(--surface)}
.rev-prem{background:linear-gradient(135deg,rgba(184,147,58,.08),rgba(184,147,58,.02));border-color:var(--accent)}
.rev-vs{display:flex;align-items:center;justify-content:center;font-family:var(--fd);font-size:1rem;font-weight:600;color:var(--accent)}
.rev-col h4{font-family:var(--fd);font-size:1.2rem;font-weight:500;margin-bottom:16px;padding-bottom:10px;border-bottom:1px solid var(--border)}
.rev-metric{display:flex;justify-content:space-between;padding:8px 0;font-size:.82rem;border-bottom:1px solid rgba(184,147,58,.06)}
.rev-metric:last-child{border-bottom:none}
.rev-metric .rv{font-family:var(--fd);font-weight:700}

/* Seasonal cards */
.season-grid{display:grid;grid-template-columns:1fr 1fr;gap:22px}
.season-card{border-radius:14px;overflow:hidden;position:relative;min-height:320px;display:flex;align-items:flex-end;transition:transform .3s}
.season-card:hover{transform:translateY(-4px)}
.season-card img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;filter:brightness(.3);transition:filter .4s}
.season-card:hover img{filter:brightness(.4)}
.season-content{position:relative;z-index:2;padding:28px;width:100%}
.season-tag{display:inline-block;padding:4px 12px;border:1px solid var(--accent);font-size:.6rem;letter-spacing:2px;text-transform:uppercase;color:var(--accent);border-radius:3px;margin-bottom:10px}
.season-content h3{font-family:var(--fd);font-size:1.6rem;font-weight:400;color:var(--brand-cream);margin-bottom:6px}
.season-content p{font-size:.8rem;color:var(--brand-tan);font-weight:200;line-height:1.7;margin-bottom:12px}
.season-items{display:flex;flex-wrap:wrap;gap:6px}
.season-item{padding:4px 10px;background:rgba(184,147,58,.12);border-radius:3px;font-size:.68rem;color:var(--accent)}
</style>
</head>
